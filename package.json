{
  "name": "purptea",
  "version": "1.0.0",
  "description": "Unified Twitch and TikTok chat viewer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "electron",
    "twitch",
    "tiktok",
    "chat",
    "streaming"
  ],
  "author": "Monstr Penguwu",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "masterchat": "^1.1.0",
    "tiktok-live-connector": "^2.1.1-beta1",
    "tmi.js": "^1.8.5"
  },
  "overrides": {
    "masterchat": {
      "axios": "^1.7.9"
    }
  },
  "build": {
    "appId": "com.purptea.app",
    "productName": "Purptea",
    "copyright": "Copyright © 2026 Monstr Penguwu",
    "publish": [
      {
        "provider": "github",
        "owner": "MonstrPenguwu",
        "repo": "Purptea"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!**/*.bak",
      "!.vscode",
      "!.github"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "publisherName": "Monstr Penguwu",
      "icon": "build/icon.ico",
      "sign": null,
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png"
    }
  }
}
